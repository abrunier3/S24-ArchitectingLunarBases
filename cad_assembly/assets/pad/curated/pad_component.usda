#usda 1.0
(
    defaultPrim = "pad"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "pad"
{
    def Xform "geo" (
        prepend references = @pad_geometry.usda@
    )
    {
        over "Object_0" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </pad/materials/surface>
        }
    }

    def Scope "materials" (
        prepend references = @pad_material.usda@
    )
    {
    }
}

